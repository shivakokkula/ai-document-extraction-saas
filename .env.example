# ════════════════════════════════════════════════════════════════
# DocuParse AI — Environment Variables
# Copy to .env and fill in your values
# ════════════════════════════════════════════════════════════════

# ─── Neon Database ───────────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"
# Use the "Direct connection" string for DIRECT_URL (migrations only)
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# ─── Upstash Redis ────────────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → Redis URL
REDIS_URL="rediss://default:xxxx@us1-xxx.upstash.io:6379"

# ─── JWT ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=generate_a_64_char_random_hex_string
JWT_REFRESH_SECRET=generate_another_64_char_random_hex_string

# ─── AWS S3 ──────────────────────────────────────────────────
# Get from: https://s3.console.aws.amazon.com → Create bucket → IAM user
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=docuparsea-uploads
# Leave blank — connects to real AWS S3
AWS_S3_ENDPOINT=

# ─── Stripe ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Get from: https://dashboard.stripe.com → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: https://dashboard.stripe.com → Products → Price ID
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── Anthropic (Claude API) ───────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── SendGrid (Email) ─────────────────────────────────────────
# Get from: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=DocuParse AI

# ─── Google OAuth ────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/v1/auth/google/callback

# ─── App URLs ────────────────────────────────────────────────
# After deploying — fill in your actual URLs
FRONTEND_URL=https://your-app.vercel.app
API_URL=https://your-backend.onrender.com
AI_SERVICE_URL=https://your-ai-service.onrender.com

NODE_ENV=production
PORT=4000

# ─── OCR Engine ──────────────────────────────────────────────
# tesseract (default, works on Render starter $7/mo)
# paddleocr  (higher accuracy, needs Render standard $25/mo)
OCR_ENGINE=tesseract
