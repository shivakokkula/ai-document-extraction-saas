# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://docuparsea:password@localhost:5432/docuparsea"
POSTGRES_USER=docuparsea
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=docuparsea

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL="redis://:password@localhost:6379"
REDIS_PASSWORD=CHANGE_ME

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=GENERATE_STRONG_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_STRONG_SECRET_HERE

# ─── AWS S3 / MinIO ──────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=docuparsea-uploads
AWS_S3_ENDPOINT=                    # Leave blank for real AWS; http://localhost:9000 for MinIO

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # Optional fallback

# ─── Email ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
FROM_EMAIL=noreply@docuparsea.com
FROM_NAME=DocuParse AI

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000
NODE_ENV=development
PORT=4000

# ─── MinIO (local dev S3) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
