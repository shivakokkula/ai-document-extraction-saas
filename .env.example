# ════════════════════════════════════════════════════════════════
# DocuParse AI — Environment Variables
# See README.md → COMPLETE SETUP GUIDE for step-by-step instructions
# ════════════════════════════════════════════════════════════════

# ─── STEP 2: Neon Database ───────────────────────────────────
# Sign up: https://neon.tech
# Project → Connect → copy BOTH strings below

# Pooled connection (has ?pgbouncer=true) — used by the app at runtime
DATABASE_URL="postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct connection (no pgbouncer) — used only for running migrations
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-south-1.aws.neon.tech/dbname?sslmode=require"

# ─── STEP 3: Upstash Redis ────────────────────────────────────
# Sign up: https://console.upstash.com → Create Database → Redis
# Must start with rediss:// (TLS enabled)
REDIS_URL="rediss://default:your_password@us1-xxx.upstash.io:6379"

# ─── STEP 4: AWS S3 ──────────────────────────────────────────
# Console: https://s3.console.aws.amazon.com
# Create bucket → IAM user with AmazonS3FullAccess → copy keys
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_S3_BUCKET=docuparsea-uploads
# Leave blank for real AWS S3. Set to http://localhost:9000 only for local MinIO.
AWS_S3_ENDPOINT=

# ─── STEP 5: Anthropic (Claude AI) ───────────────────────────
# Sign up: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── STEP 6: Stripe ──────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com → Developers → API Keys
# Use sk_test_ / pk_test_ for dev, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Dashboard → Webhooks → Add endpoint → copy signing secret
# Local dev: run `stripe listen --forward-to localhost:4000/api/v1/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Dashboard → Products → create Pro + Enterprise plans → copy Price IDs
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── STEP 7: SendGrid (Email) ─────────────────────────────────
# Sign up: https://sendgrid.com → Settings → API Keys → Create Key
SENDGRID_API_KEY=SG....
# Must be verified in SendGrid → Settings → Sender Authentication
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=DocuParse AI

# ─── STEP 8: Google OAuth (Optional) ─────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Leave blank to disable Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: http://localhost:4000/api/v1/auth/google/callback
# Prod: https://your-backend.onrender.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ─── STEP 9: JWT Secrets ─────────────────────────────────────
# Generate both with:
# node -e "const c=require('crypto'); console.log(c.randomBytes(64).toString('hex'));"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_another_64_char_random_hex

# ─── App URLs ────────────────────────────────────────────────
# Dev values shown — update to production URLs after deployment
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000
NODE_ENV=development
PORT=4000

# ─── OCR Engine ──────────────────────────────────────────────
# tesseract = lighter, works on Render Starter ($7/mo) — recommended to start
# paddleocr = more accurate, needs Render Standard ($25/mo) with 2GB+ RAM
OCR_ENGINE=tesseract
